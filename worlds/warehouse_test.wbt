#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/robots/robotis/turtlebot/protos/TurtleBot3Burger.proto"

WorldInfo {
  title "Warehouse"
  defaultDamping Damping {
    linear 0.5
    angular 0.5
  }
}
Viewpoint {
  orientation 0.013375429845365636 0.9986480552301772 -0.05023106271458645 0.7057125184005039
  position -10.912745594278084 0.284851927525409 11.401368087714541
}
Background {
  skyColor [
    0.15 0.15 0.2
  ]
}
DirectionalLight {
  direction 0 -1 -0.3
  intensity 0.8
  castShadows TRUE
}
DEF FLOOR Solid {
  translation 3 0 0
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.5 0.5 0.5
        roughness 0.9
        metalness 0
      }
      geometry DEF FLOOR_SHAPE Plane {
        size 8 12
      }
    }
  ]
  name "floor"
  boundingObject USE FLOOR_SHAPE
}
DEF WALL Solid {
  translation 7 0 0.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.35
      }
      geometry DEF WALL_FRONT_BACK_SHAPE Box {
        size 0.1 12 1
      }
    }
  ]
  name "wall_south"
  boundingObject USE WALL_FRONT_BACK_SHAPE
}
DEF WALL Solid {
  translation -1.01 0 0.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.35
      }
      geometry USE WALL_FRONT_BACK_SHAPE
    }
  ]
  name "wall_south(1)"
  boundingObject USE WALL_FRONT_BACK_SHAPE
}
DEF WALL Solid {
  translation 3 6.01 0.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.35
      }
      geometry DEF WALL_LEFT_RIGHT_SHAPE Box {
        size 8 0.1 1
      }
    }
  ]
  name "wall_west"
  boundingObject USE WALL_LEFT_RIGHT_SHAPE
}
DEF WALL Solid {
  translation 3 -6 0.5
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.3 0.3 0.35
      }
